rules_version = '2';

// OfflineSMS Firestore security rules.
// Principles:
//   - Only signed-in users can read/write anything.
//   - Each user can only modify their own profile.
//   - Chat docs and messages are restricted to chat members.
//   - Group docs and messages are restricted to group members.
//   - Senders cannot impersonate other users (senderId must match auth uid).
//   - Pin / mute / archive state on a chat can only be flipped for the
//     acting user's own uid, never for someone else.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    /** Returns true if the only difference between two list fields is the
     *  addition or removal of `uid` (any other diff is rejected). */
    function listDiffOnlyTouchesSelf(before, after, uid) {
      return before.toSet().difference(after.toSet()).hasOnly([uid])
        && after.toSet().difference(before.toSet()).hasOnly([uid]);
    }

    // --- users -------------------------------------------------------------
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    // --- chats (1:1) -------------------------------------------------------
    match /chats/{chatId} {
      function chatMembers() {
        return resource.data.members;
      }
      function isMember() {
        return signedIn() && request.auth.uid in chatMembers();
      }
      function willBeMember() {
        return signedIn() && request.auth.uid in request.resource.data.members;
      }

      // Pin/mute/archive arrays: an update can only add or remove the
      // acting user's own uid from each of these arrays. The arrays may
      // be absent in either snapshot (treated as empty).
      function selfOnlyFlagChanges() {
        return listDiffOnlyTouchesSelf(
          resource.data.get('pinnedBy', []),
          request.resource.data.get('pinnedBy', []),
          request.auth.uid
        )
        && listDiffOnlyTouchesSelf(
          resource.data.get('mutedBy', []),
          request.resource.data.get('mutedBy', []),
          request.auth.uid
        )
        && listDiffOnlyTouchesSelf(
          resource.data.get('archivedBy', []),
          request.resource.data.get('archivedBy', []),
          request.auth.uid
        );
      }

      allow read: if isMember();
      // Creator must include themselves and exactly 2 members for a 1:1 chat.
      allow create:
        if willBeMember()
        && request.resource.data.members.size() == 2;
      // Members can update last-message metadata, their own unread counter,
      // and toggle their own pin / mute / archive flags. The members list
      // itself is immutable here (no add/remove for 1:1 chats).
      allow update:
        if isMember()
        && request.resource.data.members == resource.data.members
        && selfOnlyFlagChanges();
      allow delete: if false;

      match /messages/{messageId} {
        function parentMembers() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        }
        function parentIsMember() {
          return signedIn() && request.auth.uid in parentMembers();
        }

        allow read: if parentIsMember();

        allow create:
          if parentIsMember()
          && request.resource.data.senderId == request.auth.uid
          && (
            (request.resource.data.get('type', 'text') == 'text'
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 4000)
            || (request.resource.data.get('type', 'text') == 'image'
              && request.resource.data.get('attachmentURL', '') is string)
          );

        // status / readBy / reactions can change. senderId, text, type,
        // attachmentURL and replyTo are immutable once created.
        allow update:
          if parentIsMember()
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.get('text', '') == resource.data.get('text', '')
          && request.resource.data.get('type', 'text') == resource.data.get('type', 'text')
          && request.resource.data.get('attachmentURL', null)
              == resource.data.get('attachmentURL', null)
          && request.resource.data.get('replyTo', null)
              == resource.data.get('replyTo', null);

        allow delete:
          if parentIsMember() && resource.data.senderId == request.auth.uid;
      }
    }

    // --- groups ------------------------------------------------------------
    match /groups/{groupId} {
      function members() {
        return resource.data.members;
      }
      function admins() {
        return resource.data.admins;
      }
      function isMember() {
        return signedIn() && request.auth.uid in members();
      }
      function isAdmin() {
        return signedIn() && request.auth.uid in admins();
      }
      function selfOnlyFlagChangesGroup() {
        return listDiffOnlyTouchesSelf(
          resource.data.get('pinnedBy', []),
          request.resource.data.get('pinnedBy', []),
          request.auth.uid
        )
        && listDiffOnlyTouchesSelf(
          resource.data.get('mutedBy', []),
          request.resource.data.get('mutedBy', []),
          request.auth.uid
        );
      }

      allow read: if isMember();
      allow create:
        if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members
        && request.auth.uid in request.resource.data.admins;
      // Members can update metadata + their own pin/mute. Membership and
      // admin changes are still admin-gated (with the self-leave exception).
      allow update:
        if isMember()
        && (
          (
            // Admin: free rein on metadata, membership, admins.
            isAdmin()
            && selfOnlyFlagChangesGroup()
          )
          || (
            // Non-admin self-removal.
            request.resource.data.members.size() == members().size() - 1
            && !(request.auth.uid in request.resource.data.members)
            && request.resource.data.admins == admins()
          )
          || (
            // Non-admin metadata-only updates including pin/mute toggle.
            request.resource.data.members == members()
            && request.resource.data.admins == admins()
            && selfOnlyFlagChangesGroup()
          )
        );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        function parentMembers() {
          return get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        }
        function parentIsMember() {
          return signedIn() && request.auth.uid in parentMembers();
        }

        allow read: if parentIsMember();

        allow create:
          if parentIsMember()
          && request.resource.data.senderId == request.auth.uid
          && (
            (request.resource.data.get('type', 'text') == 'text'
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 4000)
            || (request.resource.data.get('type', 'text') == 'image'
              && request.resource.data.get('attachmentURL', '') is string)
          );

        allow update:
          if parentIsMember()
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.get('text', '') == resource.data.get('text', '')
          && request.resource.data.get('type', 'text') == resource.data.get('type', 'text')
          && request.resource.data.get('attachmentURL', null)
              == resource.data.get('attachmentURL', null)
          && request.resource.data.get('replyTo', null)
              == resource.data.get('replyTo', null);

        allow delete:
          if parentIsMember() && resource.data.senderId == request.auth.uid;
      }
    }

    // --- typing indicators ------------------------------------------------
    // Path: typing/{chatId}/users/{uid}. Each doc carries the typing
    // user's own state with a server timestamp. Stale entries are
    // filtered client-side; explicit deletes are also allowed.
    match /typing/{chatId}/users/{uid} {
      allow read: if signedIn();
      allow write: if isSelf(uid)
        && request.resource.data.uid == uid;
      allow delete: if isSelf(uid);
    }

    // --- statuses (24h stories) -------------------------------------------
    match /statuses/{statusId} {
      allow read: if signedIn();
      allow create:
        if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.type in ['text', 'image'];
      // After creation only viewedBy can grow, and only with the viewer
      // adding themselves (not stripping others).
      allow update:
        if signedIn()
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.expiresAt == resource.data.expiresAt
        && request.resource.data.type == resource.data.type
        && resource.data.get('viewedBy', []).toSet()
            .difference(request.resource.data.get('viewedBy', []).toSet()).size() == 0
        && request.resource.data.get('viewedBy', []).toSet()
            .difference(resource.data.get('viewedBy', []).toSet())
            .hasOnly([request.auth.uid]);
      allow delete:
        if signedIn() && resource.data.authorId == request.auth.uid;
    }

    // --- calls (log only — actual signaling not implemented) --------------
    match /calls/{callId} {
      function participants() {
        return resource.data.participants;
      }
      allow read: if signedIn() && request.auth.uid in participants();
      allow create:
        if signedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.initiatedBy == request.auth.uid
        && request.resource.data.kind in ['voice', 'video'];
      allow update:
        if signedIn()
        && request.auth.uid in participants()
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.initiatedBy == resource.data.initiatedBy;
      allow delete: if false;
    }

    // --- contacts (each user's personal address book) ---------------------
    match /contacts/{uid}/list/{contactId} {
      allow read, write: if isSelf(uid);
    }

    // --- notifications ----------------------------------------------------
    match /notifications/{uid}/items/{notifId} {
      allow read, write: if isSelf(uid);
    }

    // --- otpRequests (server-only) ----------------------------------------
    // OTP material lives here. The admin SDK in Cloud Functions bypasses
    // these rules; clients are denied entirely.
    match /otpRequests/{phoneNumber} {
      allow read, write: if false;
    }
  }
}
