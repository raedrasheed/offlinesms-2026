rules_version = '2';

// OfflineSMS Firebase Storage rules.
service firebase.storage {
  match /b/{bucket}/o {

    // Profile avatars: each user can write only their own avatar.
    match /avatars/{uid}.jpg {
      allow read: if request.auth != null;
      allow write:
        if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Chat & group attachments: any signed-in user can read; writes require
    // matching senderId in the upload path so a user can't impersonate.
    match /chats/{chatId}/{userId}/{file} {
      allow read: if request.auth != null;
      allow write:
        if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024;
    }
    match /groups/{groupId}/{userId}/{file} {
      allow read: if request.auth != null;
      allow write:
        if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024;
    }
  }
}
