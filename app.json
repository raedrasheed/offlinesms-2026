{
  "expo": {
    "name": "OfflineSMS",
    "slug": "offlinesms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.offlinesms.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.offlinesms.app",
      "permissions": ["READ_CONTACTS", "RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-image-picker",
      "expo-notifications",
      "expo-localization",
      [
        "expo-contacts",
        {
          "contactsPermission": "OfflineSMS uses your contacts to find friends already on OfflineSMS so you can message them."
        }
      ]
    ],
    "extra": {
      "firebase": {
        "apiKey": "AIzaSyDm15bRZOoTpqTRXkbivEuJke3pRYbRNrQ",
        "authDomain": "offlinesms-prod-2026.firebaseapp.com",
        "projectId": "offlinesms-prod-2026",
        "storageBucket": "offlinesms-prod-2026.firebasestorage.app",
        "messagingSenderId": "224454037992",
        "appId": "1:224454037992:web:c0d016ac1d5c12bb07d45d"
      }
    }
  }
}
